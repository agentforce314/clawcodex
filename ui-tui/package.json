{
  "name": "clawcodex-tui",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript Ink TUI client for the clawcodex Python agent-server (Direct Connect cc://).",
  "type": "module",
  "bin": {
    "clawcodex-tui": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test test/features.test.mjs",
    "start": "node dist/cli.js",
    "dev": "bun run src/cli.tsx"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.0",
    "auto-bind": "^5.0.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.4.0",
    "cli-boxes": "^3.0.0",
    "cli-highlight": "^2.1.11",
    "code-excerpt": "^4.0.0",
    "diff": "^8.0.3",
    "emoji-regex": "^10.4.0",
    "get-east-asian-width": "^1.3.0",
    "highlight.js": "^11.11.1",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.17.21",
    "react": "^19.0.0",
    "react-reconciler": "0.33.0",
    "semver": "^7.6.0",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^3.1.0",
    "type-fest": "^4.30.0",
    "usehooks-ts": "^3.1.0",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
