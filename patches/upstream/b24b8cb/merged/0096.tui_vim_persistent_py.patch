-RecordedChange = Union[
-    InsertChange,
-    OperatorChange,
-    OperatorTextObjChange,
-    OperatorFindChange,
-    ReplaceChange,
-    XChange,
-    ToggleCaseChange,
-    IndentChange,
-    OpenLineChange,
-    JoinChange,
-]
