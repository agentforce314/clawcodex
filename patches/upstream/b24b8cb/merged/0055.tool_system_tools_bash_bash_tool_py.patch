-def _try_extract_cd(command: str) -> Path | None:
-    stripped = command.strip()
-    if not stripped.startswith("cd "):
-        return None
-    try:
-        parts = shlex.split(stripped, posix=True)
-    except ValueError:
-        return None
-    if len(parts) >= 2 and parts[0] == "cd":
-        return Path(parts[1])
-    return None
