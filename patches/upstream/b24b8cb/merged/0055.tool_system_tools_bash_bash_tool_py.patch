+
+def _bash_activity(input_data: dict | None) -> str | None:
+    if not input_data:
+        return "Running command"
+    cmd = input_data.get("command", "")
+    desc = input_data.get("description")
+    if desc:
+        return f"Running {desc}"
+    return f"Running {cmd[:60]}" if cmd else "Running command"
+
