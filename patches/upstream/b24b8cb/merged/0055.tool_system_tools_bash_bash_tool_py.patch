+    re.compile(r"\bdd\b\s+if=", re.IGNORECASE),
+    re.compile(r"\brm\b.*\s+-rf\s+/\s*$", re.IGNORECASE),
+    re.compile(r"\brm\b.*\s+-rf\s+/\s+"),
+    re.compile(r":\(\)\s*\{\s*:\s*\|\s*:\s*&\s*\}\s*;\s*:", re.IGNORECASE),
+]
