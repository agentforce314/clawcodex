-        if not self._message_buffer:
-            return
-
-        if last_id:
-            confirmed_idx: int | None = None
-            for i, msg in enumerate(self._message_buffer):
-                if msg.get('uuid') == last_id:
-                    confirmed_idx = i
-                    break
-            if confirmed_idx is not None:
