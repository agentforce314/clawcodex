-        logger.debug(
-            'WebSocketTransport: replaying %d buffered messages',
-            len(self._message_buffer),
-        )
-        logger.info(
-            'WebSocketTransport: cli_websocket_messages_to_replay '
-            'count=%d', len(self._message_buffer),
