+"""HTTP call handler — makes bounded HTTP requests safely."""
+
+from __future__ import annotations
+
+import json
+import urllib.request
+import urllib.error
+from typing import Any
+
+
+class HttpCallError(Exception):
+    """Raised when an HTTP request fails."""
+
+    pass
+
+
+def execute_http(call_impl: dict[str, Any], params: dict[str, Any]) -> str:
+    """Execute an HTTP request from a validated template.
+
+    Args:
+        call_impl: Dict with ``method`` and ``url`` keys, each containing
+            ``{placeholder}`` tokens that are filled from ``params``.
+        params: Mapping of placeholder names to resolved values.
+
+    Returns:
+        Response body as a string.
+
+    Raises:
+        HttpCallError: On request failure or non-2xx response.
+    """
+    method = call_impl.get("method", "GET").upper()
+    url = call_impl.get("url", "")
+
+    try:
+        url = url.format(**params)
+    except KeyError as exc:
+        raise HttpCallError(f"Missing parameter in URL template: {exc}") from exc
+    except Exception as exc:
+        raise HttpCallError(f"Failed to format URL template: {exc}") from exc
+
+    headers: dict[str, str] = {
+        "Accept": "application/json",
+        "User-Agent": "Claude-Code/1.0 (agent-created-tool)",
+    }
+
+    body: bytes | None = None
+    if method in {"POST", "PUT", "PATCH"}:
+        body_data = call_impl.get("body", {})
+        if isinstance(body_data, dict):
+            try:
+                body = json.dumps(body_data).encode("utf-8")
+                headers["Content-Type"] = "application/json"
+            except Exception:
+                body = json.dumps({"error": "invalid body"}).encode("utf-8")
+                headers["Content-Type"] = "application/json"
+
+    try:
+        req = urllib.request.Request(url, method=method, data=body, headers=headers)
+        with urllib.request.urlopen(req, timeout=30) as resp:
+            return resp.read().decode("utf-8")
+    except urllib.error.HTTPError as exc:
+        raise HttpCallError(f"HTTP {exc.code} {exc.reason}: {exc.read().decode('utf-8', errors='replace')}") from exc
+    except urllib.error.URLError as exc:
+        raise HttpCallError(f"URL error: {exc.reason}") from exc
+    except Exception as exc:
+        raise HttpCallError(f"Request failed: {exc}") from exc
