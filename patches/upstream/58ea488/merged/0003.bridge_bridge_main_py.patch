+    BridgeFatalError,
+    create_bridge_api_client,
+    is_expired_error_type,
+)
+from src.bridge.poll_config_defaults import (
+    DEFAULT_POLL_CONFIG,
+    PollIntervalConfig,
+)
+from src.bridge.session_runner import (
+    SessionSpawnerDeps,
+    create_session_spawner,
+)
+from src.bridge.types import (
+    BridgeApiClient,
