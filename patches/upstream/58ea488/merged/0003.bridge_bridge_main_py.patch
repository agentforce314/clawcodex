-    explicitly rejected — those depend on perpetual mode which the MVP
-    doesn't yet support.
-    """
-    out = ParsedArgs()
-    i = 0
-    while i < len(args):
-        arg = args[i]
-        if arg in ('--help', '-h'):
-            out.help = True
-        elif arg in ('--verbose', '-v'):
-            out.verbose = True
-        elif arg == '--sandbox':
-            out.sandbox = True
-        elif arg == '--no-sandbox':
-            out.sandbox = False
-        elif arg == '--debug-file' and i + 1 < len(args):
-            i += 1
