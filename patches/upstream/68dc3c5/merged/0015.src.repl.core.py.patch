From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2000
From: system <system@local>
Date: Mon May 26 2026 00:00:00 +0000
Subject: [PATCH] repl: merge b125e16 + 68dc3c5 modifications for src/repl/core.py

This patch applies both:
1. b125e16: Shift+Tab permission mode cycling (~line 538)
2. 68dc3c5: TUI context guard check (~line 2000)

Applied in order: b125e16 first, then 68dc3c5.

---
 src/repl/core.py | 60 ++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 60 insertions(+)

diff --git a/src/repl/core.py b/src/repl/core.py
index 5fac262..76d509f 100644
--- a/src/repl/core.py
+++ b/src/repl/core.py
@@ -538,6 +538,51 @@ class ClawcodexREPL:
                     # but at least the expansion lands in scrollback.
                     self._do_expand_last()

+            @self.bindings.add("s-tab")  # type: ignore[attr-defined]
+            def _cycle_permission_mode(event):  # type: ignore[no-untyped-def]
+                """Shift+Tab: cycle through permission modes.
+
+                Mirrors the TypeScript Ink reference's Shift+Tab binding
+                for cycling through default → acceptEdits → plan →
+                bypassPermissions → default.
+                """
+                from src.permissions import cycle_permission_mode
+
+                ctx = self.tool_context
+                if ctx is None:
+                    return
+                current_mode = ctx.permission_context.mode
+                is_bypass_available = (
+                    self._is_bypass_permissions_mode_available
+                )
+                # Build a context for cycle_permission_mode
+                from src.permissions.types import ToolPermissionContext
+                cycle_ctx = ToolPermissionContext(
+                    mode=current_mode,
+                    is_bypass_permissions_mode_available=is_bypass_available,
+                )
+                next_mode, next_ctx = cycle_permission_mode(cycle_ctx)
+                # Update the REPL's permission state
+                self._permission_mode = next_mode
+                ctx.permission_context = next_ctx
+                # Update the tool context's permission handler if mode changed
+                if next_mode == "bypassPermissions":
+                    ctx.permission_handler = lambda _tn, _msg, _sug: (True, False)
+                    ctx.allow_docs = True
+                else:
+                    ctx.permission_handler = self._handle_permission_request
+                    ctx.allow_docs = False
+                # Mode change is reflected in the bottom toolbar (mode: {perm_mode})
+                # No additional notification needed since toolbar updates on next prompt

         self.prompt_session = PromptSession(
             history=FileHistory(str(history_file)),
             auto_suggest=AutoSuggestFromHistory(),
@@ -575,8 +620,12 @@ class ClawcodexREPL:
             model = getattr(self.provider, "model", "") or "?"
             cwd_full = str(self.tool_context.cwd or self.tool_context.workspace_root)
             cwd = self._shorten_path_text(cwd_full) or cwd_full
+            # Get current permission mode for display
+            from src.permissions import permission_mode_short_title
+            perm_mode = permission_mode_short_title(self._permission_mode)
             return (
                 f" {provider} · {model} · {cwd} · "
+                f"mode: {perm_mode} · "
                 f"turns: {self._stats_turns} · "
                 f"tokens: {self._stats_input_tokens} in / "
                 f"{self._stats_output_tokens} out "
@@ -2000,6 +2049,13 @@ class ClawcodexREPL:
             )
             return

+        if self.tool_context is None:
+            self.console.print(
+                "[red]TUI requires an API key to function.[/red]\n"
+                "[dim]Use [bold]/login[/bold] to configure, or set [cyan]ANTHROPIC_API_KEY[/cyan] env var, then restart.[/dim]"
+            )
+            return
+
         self.console.print("[dim]Entering Textual TUI. Press Ctrl+D or type /exit to return.[/dim]")
         app = ClawCodexTUI(
             provider=self.provider,