+"""orchestrator dashboard — standalone LiveView UI.
+
+Usage:
+  clawcodex orchestrator dashboard --port 8080
+
+Launches a standalone HTTP server that streams real-time orchestrator events
+to a web-based dashboard. Agents push events to a local event log, and the
+dashboard server reads these logs to render a web UI.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import threading
+import time
+from pathlib import Path
+from typing import Any
+
+
+def add_dashboard_parser(subparsers: argparse._SubParsersAction) -> None:
+    parser = subparsers.add_parser(
+        "dashboard",
+        help="Launch standalone LiveView dashboard UI",
+        description="Start an HTTP server with a web dashboard for real-time "
+                    "orchestrator monitoring. Streams running sessions, tool calls, "
+                    "and LLM responses.",
+    )
+    parser.add_argument(
+        "--port",
+        type=int,
+        default=8080,
+        help="Port to listen on (default: 8080)",
+    )
+    parser.add_argument(
+        "--host",
+        default="127.0.0.1",
+        help="Host to bind to (default: 127.0.0.1)",
+    )
+
+
+def run(args: argparse.Namespace) -> int:
+    """Execute the orchestrator dashboard command."""
+    port = args.port
+    host = args.host
+
+    print(f"[dashboard] Starting LiveView dashboard on {host}:{port}")
+    print("[dashboard] This will open in your browser at http://{host}:{port}".format(host=host, port=port))
+
+    try:
+        from http.server import HTTPServer, SimpleHTTPRequestHandler
+        import webbrowser
+
+        workspace_root = _resolve_workspace_root()
+        dashboard_dir = _create_dashboard_files()
+
+        class DashboardHandler(SimpleHTTPRequestHandler):
+            def __init__(self, *args: Any, **kwargs: Any) -> None:
+                super().__init__(*args, directory=str(dashboard_dir), **kwargs)
+
+            def do_GET(self) -> None:
+                if self.path == "/events":
+                    self.send_response(200)
+                    self.send_header("Content-Type", "text/event-stream")
+                    self.send_header("Cache-Control", "no-cache")
+                    self.end_headers()
+                    self._stream_events()
+                else:
+                    super().do_GET()
+
+            def _stream_events(self) -> None:
+                """Stream orchestrator events as SSE."""
+                workspace = _resolve_workspace_root()
+                registry_path = workspace / ".clawcodex_issue_registry.json"
+                event_dir = workspace / ".event_logs"
+
+                def generate():
+                    known_files = set()
+                    while True:
+                        # Send registry state
+                        if registry_path.exists():
+                            try:
+                                import json
+                                registry_data = json.loads(registry_path.read_text())
+                                state = {
+                                    "type": "state",
+                                    "running": list(_get_running_issues(registry_data)),
+                                    "completed": len(registry_data),
+                                }
+                                yield f"data: {json.dumps(state)}\n\n"
+                            except Exception:
+                                pass
+
+                        # Stream new events
+                        if event_dir.exists():
+                            for log_file in event_dir.glob("*.ndjson"):
+                                if log_file.stat().st_size > 0:
+                                    with open(log_file, "r", encoding="utf-8") as f:
+                                        for line in f:
+                                            if line.strip():
+                                                yield f"data: {line.strip()}\n\n"
+
+                        time.sleep(0.5)
+
+                try:
+                    for item in generate():
+                        self.wfile.write(item.encode("utf-8"))
+                        self.wfile.flush()
+                except Exception:
+                    pass
+
+        server = HTTPServer((host, port), DashboardHandler)
+        threading.Thread(target=lambda: server.serve_forever(), daemon=True).start()
+
+        webbrowser.open(f"http://{host}:{port}")
+        print(f"[dashboard] Serving at http://{host}:{port}", file=__import__('sys').stderr)
+        print("[dashboard] Press Ctrl+C to stop", file=__import__('sys').stderr)
+
+        while True:
+            time.sleep(1)
+    except KeyboardInterrupt:
+        print("\n[dashboard] stopped")
+    except Exception as exc:
+        print(f"[dashboard] error: {exc}", file=__import__('sys').stderr)
+        return 1
+
+    return 0
+
+
+def _resolve_workspace_root() -> Path:
+    import os
+    ws = os.environ.get("CLAWCODEX_WORKSPACE_ROOT")
+    if ws:
+        return Path(ws)
+    return Path.home() / ".clawcodex" / "workspace"
+
+
+def _get_running_issues(registry_data: dict) -> list:
+    """Extract running issue IDs from registry data."""
+    running = []
+    for record in registry_data.values():
+        status = record.get("status", "")
+        if status in ("pending", "synced"):
+            running.append(record.get("issue_id", "?"))
+    return running
+
+
+def _create_dashboard_files() -> Path:
+    """Create dashboard HTML/JS files in a temp directory."""
+    import tempfile
+
+    temp_dir = Path(tempfile.mkdtemp())
+
+    html = """<!DOCTYPE html>
+<html>
+<head>
+  <title>ClawCodex Orchestrator LiveView</title>
+  <meta charset="utf-8">
+  <style>
+    * { box-sizing: border-box; }
+    body { font-family: monospace; background: #0d1117; color: #c9d1d9; margin: 0; padding: 20px; }
+    h1 { color: #58a6ff; font-size: 18px; }
+    .stats { display: flex; gap: 20px; margin-bottom: 20px; }
+    .stat { background: #161b22; padding: 10px 15px; border-radius: 6px; }
+    .stat-value { font-size: 24px; color: #58a6ff; }
+    .stat-label { font-size: 12px; color: #8b949e; }
+    .events { background: #161b22; border-radius: 6px; padding: 10px; height: 400px; overflow-y: auto; }
+    .event { padding: 4px 8px; border-bottom: 1px solid #21262d; font-size: 13px; }
+    .event-time { color: #8b949e; margin-right: 8px; }
+    .event-tool { color: #7ee787; }
+    .event-err { color: #f85149; }
+    .event-text { color: #c9d1d9; }
+  </style>
+</head>
+<body>
+  <h1>ClawCodex Orchestrator LiveView</h1>
+  <div class="stats">
+    <div class="stat"><div class="stat-value" id="running">0</div><div class="stat-label">RUNNING</div></div>
+    <div class="stat"><div class="stat-value" id="completed">0</div><div class="stat-label">COMPLETED</div></div>
+  </div>
+  <div class="events" id="events"></div>
+  <script>
+    const eventsEl = document.getElementById('events');
+    const runningEl = document.getElementById('running');
+    const completedEl = document.getElementById('completed');
+
+    const evtSource = new EventSource('/events');
+    let runningCount = 0;
+
+    evtSource.onmessage = (e) => {
+      const data = JSON.parse(e.data);
+      if (data.type === 'state') {
+        runningCount = data.running ? data.running.length : 0;
+        runningEl.textContent = runningCount;
+        completedEl.textContent = data.completed || 0;
+      } else {
+        const ts = data.timestamp || '';
+        let cls = 'event-text';
+        let msg = '';
+        if (data.type === 'tool_call') {
+          cls = 'event-tool';
+          msg = `TOOL  ${data.tool_name}`;
+        } else if (data.type === 'tool_result') {
+          cls = data.is_error ? 'event-err' : 'event-tool';
+          msg = `RESULT ${data.tool_name}`;
+        } else if (data.type === 'text_delta') {
+          msg = data.content ? data.content.slice(0,80).replace(/\\n/g,' ') : '';
+        }
+        const div = document.createElement('div');
+        div.className = 'event';
+        div.innerHTML = `<span class="event-time">${ts}</span><span class="${cls}">${msg}</span>`;
+        eventsEl.appendChild(div);
+        eventsEl.scrollTop = eventsEl.scrollHeight;
+        // Keep last 500 events
+        while (eventsEl.children.length > 500) eventsEl.removeChild(eventsEl.firstChild);
+      }
+    };
+  </script>
+</body>
+</html>"""
+
+    (temp_dir / "index.html").write_text(html, encoding="utf-8")
+    return temp_dir
\ No newline at end of file
